//@ run-pass
// HumanEval 054: Valid BST Inorder
//
// Check if an array represents a valid BST inorder traversal.
// A valid inorder traversal of a BST is strictly sorted (ascending)
// with no duplicate values.

fn is_valid_bst_inorder(arr: [i64; 256], n: i64) -> i64 with Mut, Panic {
    if n <= 1 { return 1 }
    var i: i64 = 1
    while i < n {
        if arr[i] <= arr[i - 1] {
            return 0
        }
        i = i + 1
    }
    1
}

fn main() -> i64 with IO, Mut, Panic, Div {
    // Test 1: [1, 2, 3, 4, 5] -> valid
    var a1: [i64; 256] = [0; 256]
    a1[0] = 1
    a1[1] = 2
    a1[2] = 3
    a1[3] = 4
    a1[4] = 5
    assert(is_valid_bst_inorder(a1, 5) == 1)

    // Test 2: [1, 3, 2, 4] -> invalid (3 > 2)
    var a2: [i64; 256] = [0; 256]
    a2[0] = 1
    a2[1] = 3
    a2[2] = 2
    a2[3] = 4
    assert(is_valid_bst_inorder(a2, 4) == 0)

    // Test 3: [5, 5, 6] -> invalid (duplicate 5)
    var a3: [i64; 256] = [0; 256]
    a3[0] = 5
    a3[1] = 5
    a3[2] = 6
    assert(is_valid_bst_inorder(a3, 3) == 0)

    // Test 4: single element -> valid
    var a4: [i64; 256] = [0; 256]
    a4[0] = 42
    assert(is_valid_bst_inorder(a4, 1) == 1)

    // Test 5: empty -> valid
    var a5: [i64; 256] = [0; 256]
    assert(is_valid_bst_inorder(a5, 0) == 1)

    // Test 6: descending [5, 4, 3, 2, 1] -> invalid
    var a6: [i64; 256] = [0; 256]
    a6[0] = 5
    a6[1] = 4
    a6[2] = 3
    a6[3] = 2
    a6[4] = 1
    assert(is_valid_bst_inorder(a6, 5) == 0)

    // Test 7: two elements ascending [3, 7] -> valid
    var a7: [i64; 256] = [0; 256]
    a7[0] = 3
    a7[1] = 7
    assert(is_valid_bst_inorder(a7, 2) == 1)

    // Test 8: two elements equal [4, 4] -> invalid
    var a8: [i64; 256] = [0; 256]
    a8[0] = 4
    a8[1] = 4
    assert(is_valid_bst_inorder(a8, 2) == 0)

    println("054_valid_bst: ALL TESTS PASSED")
    0
}
