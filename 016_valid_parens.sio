//@ run-pass
// HumanEval 016: Valid Parentheses
//
// Check if a byte array of parentheses (){}[] is balanced.
// Uses a stack-based approach with a fixed-size stack array.
// Byte values: ( = 40, ) = 41, [ = 91, ] = 93, { = 123, } = 125

struct Stack { data: [i64; 256], top: i64 }

fn is_open(ch: i64) -> i64 {
    if ch == 40 { return 1 }
    if ch == 91 { return 1 }
    if ch == 123 { return 1 }
    0
}

fn matching_open(close: i64) -> i64 {
    if close == 41 { return 40 }
    if close == 93 { return 91 }
    if close == 125 { return 123 }
    0
}

fn valid_parens(bytes: [i64; 256], n: i64) -> i64 with Mut, Panic {
    var stk = Stack { data: [0; 256], top: 0 }
    var i: i64 = 0
    while i < n {
        let ch = bytes[i]
        if is_open(ch) == 1 {
            stk.data[stk.top] = ch
            stk.top = stk.top + 1
        } else {
            // Closing bracket
            if stk.top == 0 {
                return 0
            }
            stk.top = stk.top - 1
            let expected = matching_open(ch)
            if stk.data[stk.top] != expected {
                return 0
            }
        }
        i = i + 1
    }
    if stk.top == 0 { 1 } else { 0 }
}

fn main() -> i64 with IO, Mut, Panic, Div {
    // ( = 40, ) = 41, [ = 91, ] = 93, { = 123, } = 125

    // Test 1: "()" -> valid
    var p1: [i64; 256] = [0; 256]
    p1[0] = 40
    p1[1] = 41
    assert(valid_parens(p1, 2) == 1)

    // Test 2: "()[]{}" -> valid
    var p2: [i64; 256] = [0; 256]
    p2[0] = 40
    p2[1] = 41
    p2[2] = 91
    p2[3] = 93
    p2[4] = 123
    p2[5] = 125
    assert(valid_parens(p2, 6) == 1)

    // Test 3: "(]" -> invalid
    var p3: [i64; 256] = [0; 256]
    p3[0] = 40
    p3[1] = 93
    assert(valid_parens(p3, 2) == 0)

    // Test 4: "([{}])" -> valid (nested)
    var p4: [i64; 256] = [0; 256]
    p4[0] = 40
    p4[1] = 91
    p4[2] = 123
    p4[3] = 125
    p4[4] = 93
    p4[5] = 41
    assert(valid_parens(p4, 6) == 1)

    // Test 5: "(((" -> invalid (unclosed)
    var p5: [i64; 256] = [0; 256]
    p5[0] = 40
    p5[1] = 40
    p5[2] = 40
    assert(valid_parens(p5, 3) == 0)

    // Test 6: empty -> valid
    var p6: [i64; 256] = [0; 256]
    assert(valid_parens(p6, 0) == 1)

    // Test 7: ")" -> invalid (close without open)
    var p7: [i64; 256] = [0; 256]
    p7[0] = 41
    assert(valid_parens(p7, 1) == 0)

    // Test 8: "{[()]}" -> valid
    var p8: [i64; 256] = [0; 256]
    p8[0] = 123
    p8[1] = 91
    p8[2] = 40
    p8[3] = 41
    p8[4] = 93
    p8[5] = 125
    assert(valid_parens(p8, 6) == 1)

    println("016_valid_parens: ALL TESTS PASSED")
    0
}
