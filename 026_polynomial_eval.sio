//@ run-pass
// HumanEval 026: Polynomial Evaluation (Horner's Method)
//
// Evaluate a polynomial P(x) = c[0] + c[1]*x + c[2]*x^2 + ... + c[n-1]*x^(n-1)
// using Horner's method: P(x) = c[0] + x*(c[1] + x*(c[2] + ... + x*c[n-1]))
// Uses integer arithmetic for exactness.

fn poly_eval(coeffs: [i64; 256], n: i64, x: i64) -> i64 with Mut, Panic {
    if n == 0 { return 0 }
    // Start from highest degree coefficient
    var result = coeffs[n - 1]
    var i = n - 2
    while i >= 0 {
        result = result * x + coeffs[i]
        i = i - 1
    }
    result
}

fn main() -> i64 with IO, Mut, Panic, Div {
    // Test 1: P(x) = 3 (constant) -> P(5) = 3
    var c1: [i64; 256] = [0; 256]
    c1[0] = 3
    assert(poly_eval(c1, 1, 5) == 3)

    // Test 2: P(x) = 2 + 3x -> P(4) = 2 + 12 = 14
    var c2: [i64; 256] = [0; 256]
    c2[0] = 2
    c2[1] = 3
    assert(poly_eval(c2, 2, 4) == 14)

    // Test 3: P(x) = 1 + 2x + 3x^2 -> P(3) = 1 + 6 + 27 = 34
    var c3: [i64; 256] = [0; 256]
    c3[0] = 1
    c3[1] = 2
    c3[2] = 3
    assert(poly_eval(c3, 3, 3) == 34)

    // Test 4: P(x) = x^3 -> P(2) = 8
    var c4: [i64; 256] = [0; 256]
    c4[3] = 1
    assert(poly_eval(c4, 4, 2) == 8)

    // Test 5: P(x) = 1 + x + x^2 + x^3 -> P(2) = 1+2+4+8 = 15
    var c5: [i64; 256] = [0; 256]
    c5[0] = 1
    c5[1] = 1
    c5[2] = 1
    c5[3] = 1
    assert(poly_eval(c5, 4, 2) == 15)

    // Test 6: P(x) = 5 - 3x + x^2 -> P(0) = 5
    var c6: [i64; 256] = [0; 256]
    c6[0] = 5
    c6[1] = 0 - 3
    c6[2] = 1
    assert(poly_eval(c6, 3, 0) == 5)

    // Test 7: P(x) = 5 - 3x + x^2 -> P(1) = 5 - 3 + 1 = 3
    var c7: [i64; 256] = [0; 256]
    c7[0] = 5
    c7[1] = 0 - 3
    c7[2] = 1
    assert(poly_eval(c7, 3, 1) == 3)

    // Test 8: P(x) = 5 - 3x + x^2 -> P(3) = 5 - 9 + 9 = 5
    var c8: [i64; 256] = [0; 256]
    c8[0] = 5
    c8[1] = 0 - 3
    c8[2] = 1
    assert(poly_eval(c8, 3, 3) == 5)

    // Test 9: empty polynomial -> 0
    var c9: [i64; 256] = [0; 256]
    assert(poly_eval(c9, 0, 100) == 0)

    println("026_polynomial_eval: ALL TESTS PASSED")
    0
}
